# Environment Configuration

# Bot Settings
BOT_NAME=WhatsApp Bot
BOT_PREFIX=/
BOT_OWNER_NUMBER=1234567890

# API Keys (Get from services below)
# Google Gemini (Free): https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI GPT (Optional): https://platform.openai.com/api-keys
# Free $5 credits on signup
OPENAI_API_KEY=your_openai_api_key_here

# Logging
LOG_LEVEL=silent

# Anti-Spam Configuration
ANTI_SPAM_ENABLED=true
MAX_MESSAGES_PER_INTERVAL=5
MESSAGE_INTERVAL_MS=10000
SPAM_WARNING_THRESHOLD=3

# Anti-Link Configuration
ANTI_LINK_ENABLED=true

# Anti-BadWord Configuration
ANTI_BADWORD_ENABLED=true

# Anti-Delete Configuration
ANTI_DELETE_ENABLED=true

# AI Configuration
AI_ENABLED=true
